# DigitalOcean API Configuration
DIGITALOCEAN_API_KEY=your_api_key_here
DIGITALOCEAN_BASE_URL=https://your-agent-endpoint.ondigitalocean.app/api/v1/
DIGITALOCEAN_MODEL=openai-gpt-5-mini

# PostgreSQL Configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=supply_chain
PGUSER=postgres
PGPASSWORD=postgres
PGSCHEMA=public

# Query Configuration
MAX_QUERY_ROWS=100
SQL_STATEMENT_TIMEOUT_MS=10000
